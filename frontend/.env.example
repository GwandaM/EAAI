# Invest Broker Agent frontend — environment template.
# Copy to frontend/.env.local if you need to override the defaults.
#
# None of these are required for local development: `npm run dev` (root)
# injects BACKEND_CHAT_URL, and when the servers are started separately the
# API routes fall back to http://localhost:3000 outside production.

# Backend chat endpoint the Next.js /api/chat route proxies to.
# REQUIRED in production. The /api/history proxy derives its base URL from
# this value unless BACKEND_BASE_URL is set explicitly.
#BACKEND_CHAT_URL=http://localhost:3000/agent/chat

# Explicit backend base URL for the /api/history proxy (overrides the value
# derived from BACKEND_CHAT_URL).
#BACKEND_BASE_URL=http://localhost:3000

# Make the browser call a backend directly instead of the Next.js /api/chat
# proxy (e.g. a separately hosted backend with CORS configured).
#NEXT_PUBLIC_CHAT_API_URL=https://api.example.com/agent/chat
