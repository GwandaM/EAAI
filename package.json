{
  "name": "enterprise-ai-agent",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "description": "Enterprise AI Agent — pnpm workspace (NestJS backend + Next.js frontend).",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "pnpm --filter enterprise-ai-agent-backend build",
    "start": "pnpm --filter enterprise-ai-agent-backend start",
    "start:dev": "pnpm --filter enterprise-ai-agent-backend start:dev",
    "start:prod": "pnpm --filter enterprise-ai-agent-backend start:prod",
    "typecheck": "pnpm --filter enterprise-ai-agent-backend typecheck",
    "lint": "pnpm --filter enterprise-ai-agent-backend lint",
    "format": "pnpm --filter enterprise-ai-agent-backend format",
    "test": "pnpm --filter enterprise-ai-agent-backend test",
    "test:e2e": "pnpm --filter enterprise-ai-agent-backend test:e2e",
    "test:bedrock": "pnpm --filter enterprise-ai-agent-backend test:bedrock",
    "backend:build": "pnpm --filter enterprise-ai-agent-backend build",
    "backend:dev": "pnpm --filter enterprise-ai-agent-backend start:dev",
    "frontend:build": "pnpm --filter enterprise-ai-agent-frontend build",
    "frontend:dev": "pnpm --filter enterprise-ai-agent-frontend dev",
    "frontend:lint": "pnpm --filter enterprise-ai-agent-frontend lint",
    "frontend:typecheck": "pnpm --filter enterprise-ai-agent-frontend typecheck",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "download:discovery-pdfs": "node scripts/download-discovery-pdfs.mjs"
  }
}
