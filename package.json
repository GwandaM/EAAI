{
  "name": "enterprise-ai-agent",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.7.0",
  "description": "Enterprise AI Agent — npm workspace (NestJS backend + Next.js frontend).",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w enterprise-ai-agent-backend",
    "start": "npm run start -w enterprise-ai-agent-backend",
    "start:dev": "npm run start:dev -w enterprise-ai-agent-backend",
    "start:prod": "npm run start:prod -w enterprise-ai-agent-backend",
    "typecheck": "npm run typecheck -w enterprise-ai-agent-backend",
    "lint": "npm run lint -w enterprise-ai-agent-backend",
    "format": "npm run format -w enterprise-ai-agent-backend",
    "test": "npm run test -w enterprise-ai-agent-backend",
    "test:e2e": "npm run test:e2e -w enterprise-ai-agent-backend",
    "test:bedrock": "npm run test:bedrock -w enterprise-ai-agent-backend",
    "tools": "npm run tools -w enterprise-ai-agent-backend --",
    "backend:build": "npm run build -w enterprise-ai-agent-backend",
    "backend:dev": "npm run start:dev -w enterprise-ai-agent-backend",
    "frontend:build": "npm run build -w enterprise-ai-agent-frontend",
    "frontend:dev": "npm run dev -w enterprise-ai-agent-frontend",
    "frontend:lint": "npm run lint -w enterprise-ai-agent-frontend",
    "frontend:typecheck": "npm run typecheck -w enterprise-ai-agent-frontend",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "download:discovery-pdfs": "node scripts/download-discovery-pdfs.mjs",
    "creds": "npm run creds -w enterprise-ai-agent-backend"
  }
}
