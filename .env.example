# --- Application ---
NODE_ENV=development
PORT=3000
# Comma-separated allowlist of browser origins permitted to call the API with
# credentials. Leave unset in development (any origin is reflected); REQUIRED in
# production, otherwise cross-origin requests are denied.
# CORS_ORIGINS=https://app.company.com,https://admin.company.com

# --- AWS (required) ---
# Region must be set explicitly. Credentials are picked up via the standard
# AWS credential chain: env vars -> ~/.aws/credentials -> EC2/ECS instance role.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
# AWS_SESSION_TOKEN=     # only required for temporary credentials (STS)

# --- Bedrock Knowledge Base ---
# Replace with your real KB ID. The default placeholder will cause RetrieveCommand to fail.
BEDROCK_KNOWLEDGE_BASE_ID=KB_PLACEHOLDER_ID

# --- Company REST API ---
COMPANY_API_BASE_URL=https://api.company.com
COMPANY_API_TOKEN=

# --- PostgreSQL (optional) ---
# If unset, the database tool returns deterministic mock rows so the agent still works.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eaai

# --- Auth (bearer JWT verified against a remote JWKS) ---
# /agent/chat requires a valid bearer token. Set AUTH_JWKS_URI to your IdP's JWKS
# endpoint; AUTH_ISSUER/AUTH_AUDIENCE are optional but strongly recommended.
# For local development only, set AUTH_DISABLED=true to bypass verification.
AUTH_DISABLED=false
AUTH_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
# AUTH_ISSUER=https://your-idp.example.com/
# AUTH_AUDIENCE=enterprise-ai-agent
