# --- Application ---
NODE_ENV=development
PORT=3000

# --- AWS (required) ---
# Region must be set explicitly. Credentials are picked up via the standard
# AWS credential chain: env vars -> ~/.aws/credentials -> EC2/ECS instance role.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
# AWS_SESSION_TOKEN=     # only required for temporary credentials (STS)

# --- Bedrock Knowledge Base ---
# Replace with your real KB ID. The default placeholder will cause RetrieveCommand to fail.
BEDROCK_KNOWLEDGE_BASE_ID=KB_PLACEHOLDER_ID

# --- Company REST API ---
COMPANY_API_BASE_URL=https://api.company.com
COMPANY_API_TOKEN=

# --- PostgreSQL (optional) ---
# If unset, the database tool returns deterministic mock rows so the agent still works.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eaai
