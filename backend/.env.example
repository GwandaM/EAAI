# Invest Broker Agent backend — environment template.
# Copy to backend/.env and fill in real values. All variables are validated at
# boot (src/config/env.validation.ts); invalid config crashes before the server
# binds, with a message naming the offending variable.

# --- Server ---
NODE_ENV=development
PORT=3005

# --- AWS / Bedrock (required) ---
# Credentials use the standard AWS chain (env -> ~/.aws/credentials -> instance
# role), so the explicit keys below are optional if another link provides them.
AWS_REGION=eu-west-1
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_SESSION_TOKEN=

# Bedrock Knowledge Base backing the queryKnowledgeBase tool (required).
BEDROCK_KNOWLEDGE_BASE_ID=

# Override the model id. Many regions require a cross-region *inference
# profile* id (eu.anthropic.… in eu-*, us.anthropic.… in us-*); the bare model
# id is rejected there as "invalid model identifier".
# Default: eu.anthropic.claude-3-5-sonnet-20241022-v2:0
#BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Business API (required) ---
# Upstream services behind the Policy and Party Service tools. They live on
# different base URLs but share the same bearer token.
POLICY_SERVICE_BASE_URL=http://localhost:8080
PARTY_SERVICE_BASE_URL=http://localhost:8081
# Shared bearer token for both services; omit if the upstreams need no auth.
# (COMPANY_API_TOKEN is accepted as a legacy alias; BEARER_TOKEN wins if both set.)
#BEARER_TOKEN=
#COMPANY_API_TOKEN=

# --- Auth (bearer JWT verified against a remote JWKS) ---
# For local development set AUTH_DISABLED=true: the frontend sends no bearer
# token, so with auth enabled every /agent/chat request is rejected with 401.
# When AUTH_DISABLED=false (the default), AUTH_JWKS_URI is required.
AUTH_DISABLED=true
#AUTH_JWKS_URI=https://your-idp.example.com/.well-known/jwks.json
#AUTH_ISSUER=https://your-idp.example.com/
#AUTH_AUDIENCE=invest-broker-agent

# --- Conversation history (optional) ---
# Postgres used only to persist chat history; leave unset to disable.
# docker-compose default: postgresql://postgres:postgres@localhost:5432/agent
#DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent

# --- CORS (optional) ---
# Comma-separated allowlist. Unset: any origin is reflected in development,
# and cross-origin requests are denied in production.
#CORS_ORIGINS=http://localhost:3001

# --- Oracle (optional; dev-only oracle.query tool harness, never model-facing) ---
# All-or-none: USER, PASSWORD and CONNECT_STRING must be set together.
#ORACLE_USER=
#ORACLE_PASSWORD=
#ORACLE_CONNECT_STRING=localhost:1521/FREEPDB1
#ORACLE_TNS_ADMIN=
#ORACLE_SCHEMA=
