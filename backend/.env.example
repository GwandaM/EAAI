# Copy to backend/.env and fill in. Validated at boot by src/config/env.validation.ts —
# missing/invalid required values crash the server before it binds.

NODE_ENV=development
PORT=3000

# --- AWS / Bedrock (required) ---
AWS_REGION=eu-central-1
# Credentials are optional: the standard AWS chain is used
# (env -> ~/.aws/credentials -> instance role). Set these only if you need to.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

BEDROCK_KNOWLEDGE_BASE_ID=your-kb-id

# Override the Bedrock model id. In many regions this must be a cross-region
# inference profile id (eu.anthropic.… in eu-*, us.anthropic.… in us-*).
# Default: eu.anthropic.claude-3-5-sonnet-20241022-v2:0
# BEDROCK_MODEL_ID=

# --- Business API (required) ---
COMPANY_API_BASE_URL=https://api.example.com
# Optional bearer token; leave unset if the upstream API does not require auth.
# COMPANY_API_TOKEN=

# --- Postgres (optional; chat-history persistence only) ---
# Unset/empty disables history. Matches docker-compose defaults:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent

# --- Oracle (optional; internal-only, dev tool harness — never model-facing) ---
# All-or-none: USER, PASSWORD and CONNECT_STRING must be set together.
# ORACLE_USER=
# ORACLE_PASSWORD=
# ORACLE_CONNECT_STRING=host:1521/service
# ORACLE_TNS_ADMIN=/path/to/tns/dir
# ORACLE_SCHEMA=

# --- CORS ---
# Comma-separated allowed origins. Unset: reflected in development only,
# denied in production.
# CORS_ORIGINS=http://localhost:3001

# --- Auth (bearer JWT verified against a remote JWKS) ---
# AUTH_JWKS_URI is required unless AUTH_DISABLED=true.
AUTH_DISABLED=true
# AUTH_JWKS_URI=https://issuer.example.com/.well-known/jwks.json
# AUTH_ISSUER=
# AUTH_AUDIENCE=
